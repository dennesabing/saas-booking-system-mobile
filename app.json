{
  "expo": {
    "name": "Koobstel",
    "slug": "koobstel",
    "scheme": "koobstel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.koobstel.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.koobstel.app"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Koobstel to access your camera for scanning QR codes."
        }
      ],
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Koobstel to access your location to set your default location."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
